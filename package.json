{
  "name": "qlcplus-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for controlling QLC+ lighting software through OSC",
  "type": "module",
  "main": "./dist/src/index.js",
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/src/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/src/index.js",
    "test": "vitest",
    "format": "prettier --write 'src/**/*.ts'",
    "generate:widgets": "tsx src/qlc/generateWidgets.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "osc-js": "^2.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/unzipper": "^0.10.11",
    "@types/xml2js": "^0.4.14",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  }
}
