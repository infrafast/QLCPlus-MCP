{
  "name": "qlcplus-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for controlling QLC+ lighting software through OSC",
  "type": "module",
  "main": "./dist/src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/src/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/src/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "generate:widgets": "tsx src/qlc/generateWidgets.ts"
  },
  "dependencies": {
    "mcp-use": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "osc-js": "^3.3.1",
    "express": "^4.18.2",
    "xml2js": "^0.6.2",
    "unzipper": "^0.11.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.1"
  }
}
