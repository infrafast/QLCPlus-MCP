# MCP Transport mode (stdio or http)
MCP_TRANSPORT=http

# HTTP Server Configuration
HTTP_HOST=0.0.0.0
HTTP_PORT=8788
HTTP_MCP_PATH=/mcp

# Authentication
MCP_AUTH_MODE=none
# MCP_AUTH_MODE=bearer
# MCP_AUTH_TOKEN=change-me

# QLC+ Configuration
QLC_HOST=192.168.0.160
QLC_OSC_INPUT_PORT=7700
QLC_OSC_OUTPUT_PORT=9000
QLC_UNIVERSE=1

# Widget Configuration
QLC_WIDGETS_FILE=config/widgets.json
QLC_ALLOW_RAW_OSC=false

# Dry Run Mode (logs OSC commands without sending)
QLC_DRY_RUN=false

# Logging
LOG_LEVEL=info
NODE_ENV=development
