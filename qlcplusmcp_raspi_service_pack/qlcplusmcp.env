# QLCPlus-MCP Raspberry Pi configuration
# Copy to: /etc/qlcplusmcp.env

QLCPLUS_MCP_DIR=/home/pi/QLCPlus-MCP

# MCP transport / HTTP server
MCP_TRANSPORT=http
HTTP_HOST=0.0.0.0
HTTP_PORT=8788
HTTP_MCP_PATH=/mcp

# Optional authentication.
# Leave MCP_AUTH_MODE=none to disable auth.
# Use MCP_AUTH_MODE=bearer and MCP_AUTH_TOKEN=your_token to enable bearer auth.
MCP_AUTH_MODE=none
MCP_AUTH_TOKEN=

# QLC+ OSC configuration
# If QLC+ runs on the same Raspberry, keep 127.0.0.1.
# If QLC+ runs on another machine in the rack LAN, use its 192.168.100.x address.
QLC_HOST=127.0.0.1
QLC_OSC_INPUT_PORT=7700
QLC_OSC_OUTPUT_PORT=9000
QLC_UNIVERSE=1

# Widget mapping file
QLC_WIDGETS_FILE=/home/pi/QLCPlus-MCP/config/widgets.json

# Safety / debug
QLC_ALLOW_RAW_OSC=true
QLC_DRY_RUN=false
LOG_LEVEL=debug
NODE_ENV=production
